{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.py": {
      "runtime": "@vercel/python@4.1.0"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src * 'unsafe-inline' 'unsafe-eval' data: blob:;"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/api/wger-media/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "cross-origin"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/api/off-images/(.*)",
      "headers": [
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/api/off-static/(.*)",
      "headers": [
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/wger-media/(.*)",
      "destination": "https://wger.de/$1"
    },
    {
      "source": "/api/wger/(.*)",
      "destination": "/api/wger?path=$1"
    },
    {
       "source": "/api/off-images/(.*)",
       "destination": "https://images.openfoodfacts.org/$1"
    },
    {
       "source": "/api/off-static/(.*)",
       "destination": "https://static.openfoodfacts.org/$1"
    },
    {
       "source": "/api/off/(.*)",
       "destination": "/api/off?path=$1"
    },
    {
      "source": "/((?!api/)(?!.*\\.[a-zA-Z0-9]{1,5}$).*)",
      "destination": "/index.html"
    }
  ]
}