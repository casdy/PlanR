{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/api/wger-media/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "cross-origin"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/wger-media/(.*)",
      "destination": "https://wger.de/$1"
    },
    {
      "source": "/api/wger/(.*)",
      "destination": "/api/wger?path=$1"
    },
    {
      "source": "/((?!api/)(?!.*\\.[a-zA-Z0-9]{1,5}$).*)",
      "destination": "/index.html"
    }
  ]
}