# ─── Supabase (Required for Auth) ─────────────────────────────────────────────
VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJ..."

# ─── Groq AI (Required for AI Routine Generation & Voice Transcription) ────────
GROQ_API_KEY="gsk_..."

# ─── ExerciseDB via RapidAPI (Required for Exercise Suggestions & Swap feature) 
RAPIDAPI_KEY="your_rapidapi_key_here"

# ─── WorkoutDB Direct API (Optional — free key from workoutdb.is-app.in) ───────
